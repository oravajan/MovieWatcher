@page "/"
@page "/watchlist"
@rendermode InteractiveWebAssembly

<PageTitle>My Watchlist</PageTitle>

@if (selectedMedia == null)
{
    <h1>My Watchlist 🍿</h1>

    <div class="row mb-4 p-3 bg-light rounded">
        <div class="col-md-7 mb-2">
            <input @bind="newItemTitle" class="form-control" placeholder="Add new title..."/>
        </div>
        <div class="col-md-3 mb-2">
            <select @bind="newItemType" class="form-select">
                <option value="Movie">🎬 Movie</option>
                <option value="Series">📺 Series</option>
            </select>
        </div>
        <div class="col-md-2 mb-2">
            <button class="btn btn-primary w-100" @onclick="AddItem">Add</button>
        </div>
    </div>

    <table class="table table-hover align-middle">
        <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in mediaItems)
        {
            <tr>
                <td>
                    <strong>@item.Title</strong>
                </td>
                <td>
                        <span class="badge fs-6 @(item.IsCompleted ? "bg-success" : "bg-info text-dark")">
                            @GetStatusDisplay(item)
                        </span>
                </td>
                <td>
                    @if (!item.IsCompleted)
                    {
                        <button class="btn btn-sm btn-success me-2" @onclick="() => WatchNext(item)">
                            @(item is MovieItem ? "✓ Watched" : "⏭ Watch Next")
                        </button>
                    }
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => ShowDetails(item)">
                        Details
                    </button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <button class="btn btn-secondary mb-3" @onclick="HideDetails">⬅ Back to List</button>

    <h2>@selectedMedia.Title</h2>

    @if (selectedMedia is MovieItem movie)
    {
        <div class="card p-4">
            <h4>Movie Status</h4>
            <div class="form-check form-switch fs-5 mt-3">
                <input class="form-check-input" type="checkbox" role="switch" id="movieStatus"
                       @bind="movie.IsCompleted"/>
                <label class="form-check-label" for="movieStatus">Mark as Watched</label>
            </div>
        </div>
    }
    else if (selectedMedia is SeriesItem series)
    {
        <div class="card p-4">
            <h4>Seasons & Episodes</h4>

            @if (!series.Seasons.Any())
            {
                <p class="text-muted mt-2">No seasons tracked yet.</p>
                <button class="btn btn-sm btn-outline-success" @onclick="() => AddSeason(series)">
                    + Add Season
                </button>
            }
            else
            {
                @foreach (var season in series.Seasons)
                {
                    <div class="mt-3">
                        <h5>Season @season.SeasonNumber</h5>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var episode in season.Episodes)
                            {
                                <button
                                    class="btn btn-sm @(episode.IsWatched ? "btn-success" : "btn-outline-secondary")"
                                    @onclick="() => ToggleEpisodeWatched(series, episode)">
                                    Ep @episode.EpisodeNumber
                                </button>
                            }
                        </div>
                    </div>
                }

                <button class="btn btn-sm btn-outline-success mt-4" @onclick="() => AddSeason(series)">
                    + Add Season
                </button>
            }
        </div>
    }
}

@code {

    /// <summary>
    /// Base abstract class for all media types. Cannot be instantiated directly.
    /// </summary>
    public abstract class MediaItem
    {
        public Guid Id { get; set; } = Guid.NewGuid();
        public string Title { get; set; } = string.Empty;
        public bool IsCompleted { get; set; }
    }

    /// <summary>
    /// Represents a movie.
    /// </summary>
    public class MovieItem : MediaItem;

    /// <summary>
    /// Represents a TV series containing multiple seasons.
    /// </summary>
    public class SeriesItem : MediaItem
    {
        public List<SeasonItem> Seasons { get; set; } = new();
    }

    public class SeasonItem
    {
        public int SeasonNumber { get; set; }
        public List<EpisodeItem> Episodes { get; set; } = new();
    }

    public class EpisodeItem
    {
        public Guid Id { get; set; } = Guid.NewGuid();
        public int EpisodeNumber { get; set; }
        public bool IsWatched { get; set; }
    }

    private string newItemTitle = string.Empty;
    private string newItemType = "Movie";

    private MediaItem? selectedMedia;
    private List<MediaItem> mediaItems = new();

    protected override void OnInitialized()
    {
        var falloutSeries = new SeriesItem { Title = "Fallout", IsCompleted = false };
        var season1 = new SeasonItem { SeasonNumber = 1 };

        for (int i = 1; i <= 8; i++)
        {
            season1.Episodes.Add(new EpisodeItem { EpisodeNumber = i, IsWatched = i <= 2 });
        }

        falloutSeries.Seasons.Add(season1);

        mediaItems.Add(new MovieItem { Title = "Dune: Part Two", IsCompleted = true });
        mediaItems.Add(falloutSeries);
    }

    private void AddItem()
    {
        if (!string.IsNullOrWhiteSpace(newItemTitle))
        {
            if (newItemType == "Movie")
            {
                mediaItems.Add(new MovieItem { Title = newItemTitle });
            }
            else
            {
                mediaItems.Add(new SeriesItem { Title = newItemTitle });
            }

            newItemTitle = string.Empty;
        }
    }

    private string GetStatusDisplay(MediaItem item)
    {
        if (item.IsCompleted) return "Completed";
        if (item is MovieItem) return "Pending";

        if (item is SeriesItem series)
        {
            if (!series.Seasons.Any()) return "No Seasons";

            foreach (var season in series.Seasons.OrderBy(s => s.SeasonNumber))
            {
                var nextEp = season.Episodes.OrderBy(e => e.EpisodeNumber).FirstOrDefault(e => !e.IsWatched);
                if (nextEp != null)
                {
                    return $"S{season.SeasonNumber:D2}E{nextEp.EpisodeNumber:D2}";
                }
            }
        }

        return "Completed";
    }

    private void WatchNext(MediaItem item)
    {
        if (item is MovieItem movie)
        {
            movie.IsCompleted = true;
            return;
        }

        if (item is SeriesItem series)
        {
            foreach (var season in series.Seasons.OrderBy(s => s.SeasonNumber))
            {
                var nextEp = season.Episodes.OrderBy(e => e.EpisodeNumber).FirstOrDefault(e => !e.IsWatched);
                if (nextEp != null)
                {
                    nextEp.IsWatched = true;
                    CheckIfSeriesCompleted(series);
                    return;
                }
            }
        }
    }

    private void ToggleEpisodeWatched(SeriesItem series, EpisodeItem episode)
    {
        episode.IsWatched = !episode.IsWatched;
        CheckIfSeriesCompleted(series);
    }

    private void CheckIfSeriesCompleted(SeriesItem series)
    {
        if (!series.Seasons.Any()) return;

        bool allWatched = series.Seasons.SelectMany(s => s.Episodes).All(e => e.IsWatched);
        series.IsCompleted = allWatched;
    }

    private void ShowDetails(MediaItem item) => selectedMedia = item;
    private void HideDetails() => selectedMedia = null;

    private void AddSeason(SeriesItem series)
    {
        var nextSeasonNum = series.Seasons.Count + 1;
        var newSeason = new SeasonItem { SeasonNumber = nextSeasonNum };

        for (int i = 1; i <= 8; i++)
        {
            newSeason.Episodes.Add(new EpisodeItem { EpisodeNumber = i, IsWatched = false });
        }

        series.Seasons.Add(newSeason);
        series.IsCompleted = false;
    }

}